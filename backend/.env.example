# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxx...
SUPABASE_SERVICE_KEY=eyJxxx...

# Gemini — quota bitince KEY_2, KEY_3, KEY_4 sırayla kullanılır
GEMINI_API_KEY=AIzaxxx...
GEMINI_API_KEY_2=AIzaxxx...
GEMINI_API_KEY_3=AIzaxxx...
GEMINI_API_KEY_4=AIzaxxx...
GEMINI_MODEL=gemini-2.5-flash

# Manus — quota bitince KEY_2, sonra KEY_3 kullanılır
MANUS_API_KEY=sk-xxx...
MANUS_API_KEY_2=sk-xxx...
MANUS_API_KEY_3=sk-xxx...
MANUS_BASE_URL=https://api.manus.im
MANUS_TIMEOUT=60
MANUS_MAX_RETRIES=2

# LLM Routing
ENABLE_MANUS=True
MANUS_ROLLOUT_PERCENTAGE=50 # Her aramada %50 ihtimalle Manus, %50 SerpAPI kullanılır

# SerpAPI
SERPAPI_KEY=your-serpapi-key

# Backup LLM (optional)
OPENAI_API_KEY=sk-xxx...

# App
ENVIRONMENT=development
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000

# Security
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]
